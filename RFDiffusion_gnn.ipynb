        "    f.write('{\"backend\": \"pytorch\"}')\n",
        "os.environ['DGLBACKEND'] = 'pytorch'\n",
        "\n",
        "# Nuclear option — uninstall everything DGL and reinstall clean\n",
        "print('\\nUninstalling all DGL variants...')\n",
        "for pkg in ['dgl', 'dglgo', 'dgl-cu121', 'dgl-cu118', 'dgl-cu117']:\n",
